<!DOCTYPE html>
<html lang="pt-BR" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' | Fertunani' : 'Fertunani Blog' %></title>
  <link rel="stylesheet" href="/css/output.css" />
  <style>
    body { font-family: 'Georgia', serif; }
    code, pre { font-family: 'Courier New', monospace; }
  </style>
</head>
<body class="bg-white dark:bg-zinc-950 text-zinc-800 dark:text-zinc-200 min-h-screen transition-colors duration-200">

  <header class="border-b border-zinc-200 dark:border-zinc-800 py-4 mb-10">
    <div class="max-w-3xl mx-auto px-4 flex items-center justify-between">
      <a href="/" class="text-lg font-bold tracking-tight hover:opacity-70 transition-opacity">
        Fertunani
      </a>
      <div class="flex items-center gap-4 text-sm">
        <a href="/feed.xml" class="text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-200 transition-colors">RSS</a>
        <button id="theme-toggle" class="text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-200 transition-colors" title="Alternar tema (CTRL+K)">
          <span id="theme-icon">☀️</span>
        </button>
      </div>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-4 pb-20">
    <%- body %>
  </main>

  <footer class="border-t border-zinc-200 dark:border-zinc-800 py-6 mt-20">
    <div class="max-w-3xl mx-auto px-4 text-sm text-zinc-400 flex justify-between">
      <span>Fertunani Blog</span>
      <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
        <div class="flex items-center gap-4">
          <a href="/posts/admin/new" class="hover:text-zinc-600 dark:hover:text-zinc-200 transition-colors">+ novo post</a>
          <form action="/logout" method="POST" class="inline">
            <button type="submit" class="hover:text-zinc-600 dark:hover:text-zinc-200 transition-colors cursor-pointer">sair</button>
          </form>
        </div>
      <% } %>
    </div>
  </footer>

  <script>
    const html = document.documentElement
    const btn = document.getElementById('theme-toggle')
    const icon = document.getElementById('theme-icon')

    const saved = localStorage.getItem('theme')
    if (saved === 'light') {
      html.classList.remove('dark')
      icon.textContent = '🌙'
    }

    btn.addEventListener('click', () => {
      const isDark = html.classList.toggle('dark')
      icon.textContent = isDark ? '☀️' : '🌙'
      localStorage.setItem('theme', isDark ? 'dark' : 'light')
    })

    document.addEventListener('keydown', e => {
      if (e.ctrlKey && e.key === 'k') {
        e.preventDefault()
        btn.click()
      }
    })
  </script>
</body>
</html>
