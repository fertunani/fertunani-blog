<div class="max-w-sm mx-auto mt-20">
  <h1 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100 mb-8">Entrar</h1>

  <% if (typeof error !== 'undefined' && error) { %>
    <p class="text-red-500 text-sm mb-4"><%= error %></p>
  <% } %>

  <form action="/login" method="POST" class="flex flex-col gap-4">
    <input
      type="password"
      name="password"
      placeholder="Senha"
      autofocus
      required
      class="w-full bg-transparent border border-zinc-300 dark:border-zinc-700 rounded px-3 py-2 text-sm text-zinc-800 dark:text-zinc-200 placeholder-zinc-400 focus:outline-none focus:border-zinc-500 dark:focus:border-zinc-400"
    />
    <button type="submit" class="w-full bg-zinc-900 dark:bg-zinc-100 text-zinc-100 dark:text-zinc-900 text-sm font-semibold py-2 rounded hover:opacity-80 transition-opacity">
      Entrar
    </button>
  </form>
</div>
